<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.coffeeonline.mapper.EmailSubscriptionMapper">

    <select id="selectByEmail" resultType="com.example.coffeeonline.entity.EmailSubscription">
        SELECT * FROM email_subscription WHERE email = #{email}
    </select>

</mapper>